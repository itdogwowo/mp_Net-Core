{
  "assets_root": "/sd",
  "debug": true,
  "scan_ignore": ["/sd"],
  "System": {
    "master_IP": "",
    "master_port": 0,
    "discovery_port": 9000,
    "heartbeat_interval": 10000,
    "log_interval_ms": 1000
  },
  "Network": {
    "priority": ["wifi", "lan"],
    "lan": { "enable": 0, "active_mode": 1 },
    "wifi": {
      "enable": 1,
      "active_mode": 2,
      "timeout": 300,
      "ssid": "",
      "ssid_pw": "",
      "mdns_name": "esp32-led-"
    }
  },
  "Buffer": {
    "size": 4096,
    "rx_hub_buffers": 8,
    "decode_budget_slots": 32,
    "drop_on_full": 1,
    "drain_reads": 1
  },
  "UART": {
    "enable": 1,
    "list": [
      { "id": 1, "baudrate": 115200, "GPIO": { "tx": 8, "rx": 18 } }
    ]
  },
  "tft": {
    "driver": "ST7789",
    "width": 240,
    "height": 320,
    "rotation": 0,
    "color_order": "RGB",
    "invert": true,
    "spi": {
      "id": 1,
      "baudrate": 80000000,
      "sck": 21,
      "mosi": 14
    },
    "pins": {
      "dc": 12,
      "cs": 11,
      "rst": 13,
      "bl": 10
    },
    "backlight": {
      "freq": 1000,
      "duty": 100,
      "invert": 0
    }
  },
  "jpeg": {
    "pixel_format": "RGB565_BE",
    "rotation": 0,
    "block": true,
    "return_bytes": false,
    "step_blocks": 0,
    "max_jpeg_bytes": 0
  },
  "display_Layout": [
    {
      "type": "output",
      "height": 240,
      "width": 320,
      "x": 0,
      "y": 0,
      "assets_pack": 1,
      "start": 0,
      "range": -1
    }
  ],
  "player": {
    "pace_ms": 33,
    "pace_frames": 1,
    "autoplay": true,
    "loop": true,
    "pipeline": {
      "io_buffers": 3,
      "frame_buffers": 3,
      "preload": 16
    },
    "stats": {
      "enabled": 1,
      "interval_ms": 1000,
      "frames_n": 60
    }
  },
  "SDcard": {
    "enable": 1,
    "phat": "/sd",
    "config": {
      "slot": 0,
      "width": 4,
      "freq": 40000000
    },
    "GPIO": {
      "sck": 7,
      "cmd": 6,
      "data": [15, 16, 4, 5]
    }
  }
}
